<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Account Center - Anekdote Auth</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/static/style.css">
</head>

<body>
    <main class="container container-lg">
        <div class="card">
            <h2>Account Center</h2>
            <p class="subtitle">Welcome back, {{ .User.Name }}</p>

            {{ if or .Error .Success }}
            <div class="alert-container">
                {{ if .Error }}
                <div class="alert error">
                    <div class="alert-content">{{ .Error }}</div>
                    <button type="button" class="alert-close" onclick="this.parentElement.remove()">&times;</button>
                </div>
                {{ end }}
                {{ if .Success }}
                <div class="alert success">
                    <div class="alert-content">{{ .Success }}</div>
                    <button type="button" class="alert-close" onclick="this.parentElement.remove()">&times;</button>
                </div>
                {{ end }}
            </div>
            {{ end }}

            <div class="profile-section">
                <h3>Profile Details</h3>
                <form method="POST" action="/account/profile">
                {{ .CSRFField }}
                    <div class="form-group">
                        <label for="name">Full Name</label>
                        <input type="text" id="name" name="name" value="{{ .User.Name }}" required>
                    </div>
                    <button type="submit" class="btn-outline">Update Profile</button>
                </form>
            </div>

            <div class="profile-section">
                <h3>Change Password</h3>
                <form method="POST" action="/account/password">
                {{ .CSRFField }}
                    <div class="form-group">
                        <label for="old_password">Current Password</label>
                        <input type="password" id="old_password" name="old_password" placeholder="••••••••" required>
                    </div>

                    <div class="form-group">
                        <label for="new_password">New Password</label>
                        <input type="password" id="new_password" name="new_password" placeholder="••••••••" required
                            minlength="6">
                    </div>

                    <button type="submit" class="btn-outline">Change Password</button>
                </form>
            </div>

            <div class="text-center" style="margin-top: 2rem;">
                <form method="POST" action="/logout">
                {{ .CSRFField }}
                    <button type="submit" class="btn-danger">Logout</button>
                </form>
            </div>
        </div>
    </main>
</body>

</html>