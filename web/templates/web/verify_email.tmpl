<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify Email - anekdote</title>
    <link rel="stylesheet" href="/static/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="card">
        <div class="logo">
            <i class="fas fa-envelope-open-text"></i>
        </div>
        <h1>Verify Email</h1>
        <p class="subtitle">Enter the 6-digit code sent to your inbox.</p>

        <div class="alert-container">
            {{ if .Error }}
            <div class="alert error">
                <i class="fas fa-exclamation-circle"></i> {{ .Error }}
                <button class="alert-close">&times;</button>
            </div>
            {{ end }}
            {{ if .Success }}
            <div class="alert success">
                <i class="fas fa-check-circle"></i> {{ .Success }}
                <button class="alert-close">&times;</button>
            </div>
            {{ end }}
        </div>

        <form method="POST" action="/verify-email">
                {{ .CSRFField }}
            <input type="hidden" name="user_id" value="{{ .UserID }}">
            <div class="form-group">
                <div class="input-icon">
                    <i class="fas fa-key"></i>
                    <input type="text" id="otp" name="otp" placeholder="6-digit OTP code" required maxlength="6" pattern="\d{6}">
                </div>
            </div>
            <button type="submit">Verify & Login</button>
        </form>
    </div>

    <!-- Script to make alerts dismissible -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const closeBtns = document.querySelectorAll('.alert-close');
            closeBtns.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const alert = e.target.closest('.alert');
                    alert.style.opacity = '0';
                    setTimeout(() => alert.remove(), 300);
                });
            });
        });
    </script>
</body>
</html>
