<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Password Reset - Anekdote Auth</title>
    <style>
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: #0b0f19;
            color: #f0f6fc;
            margin: 0;
            padding: 0;
            line-height: 1.6;
        }

        .container {
            max-width: 600px;
            margin: 40px auto;
            padding: 20px;
        }

        .card {
            background-color: #161b22;
            border: 1px solid #30363d;
            border-radius: 12px;
            padding: 32px;
            text-align: center;
        }

        .header {
            margin-bottom: 24px;
        }

        .header h2 {
            margin: 0;
            color: #58a6ff;
            font-size: 24px;
        }

        .content {
            font-size: 16px;
            color: #c9d1d9;
            margin-bottom: 32px;
        }

        .button {
            display: inline-block;
            background-color: #58a6ff;
            color: #ffffff;
            font-weight: 600;
            text-decoration: none;
            padding: 12px 24px;
            border-radius: 8px;
            margin-bottom: 24px;
        }

        .footer {
            font-size: 12px;
            color: #8b949e;
            margin-top: 32px;
            border-top: 1px solid #30363d;
            padding-top: 24px;
        }

        a {
            color: #58a6ff;
            text-decoration: none;
        }

        .link-text {
            font-size: 14px;
            word-wrap: break-word;
            color: #8b949e;
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="card">
            <div class="header">
                <h2>Password Reset Request</h2>
            </div>
            <div class="content">
                <p>Hello,</p>
                <p>We received a request to reset your password for your <strong>Anekdote Auth</strong> account.</p>
                <p>Click the button below to securely create a new password:</p>
            </div>

            <a href="{{ .ResetLink }}" class="button" style="color: #ffffff;">Reset Password</a>

            <div class="content">
                <p>If the button doesn't work, copy and paste this link into your browser:</p>
                <p class="link-text"><a href="{{ .ResetLink }}">{{ .ResetLink }}</a></p>
            </div>

            <div class="footer">
                <p>If you did not request this, please ignore this email. Your password will remain unchanged.</p>
                <p>&copy; 2026 Anekdote Auth. All rights reserved.</p>
            </div>
        </div>
    </div>
</body>

</html>